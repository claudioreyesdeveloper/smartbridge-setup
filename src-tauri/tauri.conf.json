{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SmartBridge Setup",
  "version": "0.2.1",
  "identifier": "com.smartbridge.installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SmartBridge Setup",
        "width": 900,
        "height": 760,
        "minWidth": 760,
        "minHeight": 680,
        "resizable": true,
        "center": true,
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Component-based installer for SmartBridge",
    "longDescription": "SmartBridge Setup detects, installs, repairs, and verifies the SmartBridge application and its optional integration components (Cubase MIDI Remote, Cubase project template, Synthesizer V side panel, AI Lyrics local model, help files).",
    "copyright": "(c) 2026 Claudio Reyes",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
